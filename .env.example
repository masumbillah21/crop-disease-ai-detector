# ─────────────────────────────────────────────────────────────
#  CropScan AI — Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Backend model paths (used by Docker volume mount)
MODEL_PATH=/app/model/crop_disease_model.h5
CLASS_NAMES_PATH=/app/model/class_names.json

# Backend server settings
BACKEND_PORT=8000
BACKEND_WORKERS=2

# Frontend API URL override (leave blank to auto-detect)
VITE_API_URL=

# Nginx proxy port
NGINX_PORT=80

# Python settings
PYTHONUNBUFFERED=1
TF_CPP_MIN_LOG_LEVEL=2
