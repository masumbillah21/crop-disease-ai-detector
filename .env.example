# CropScan AI — Environment Variables
# cp .env.example .env

# Model paths (used inside Docker container)
MODEL_PATH=/app/model/crop_disease_model
CLASS_NAMES_PATH=/app/model/class_names.json
DATASET_DIR=./dataset/plantvillage/plantvillage dataset/color
MODEL_SAVE_PATH=./crop_disease_model.h5

# Python settings
PYTHONUNBUFFERED=1
TF_CPP_MIN_LOG_LEVEL=2
